<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="fragment"
            type="org.amnezia.awg.fragment.TunnelListFragment" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/vpn_button"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/surfboost"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Connect VPN" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Disconnected"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline5" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/profile_spinner"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_background"
                    android:dropDownVerticalOffset="4dp"
                    android:dropDownSelector="@android:color/transparent"
                    android:popupBackground="@drawable/spinner_popup_background"
                    android:spinnerMode="dropdown" />

                <ImageButton
                    android:id="@+id/refresh_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Refresh servers"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_refresh"
                    app:tint="?attr/colorOnSurface" />

            </LinearLayout>

        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
